# ============================================================
# Research Powerpack MCP - Environment Variables
# ============================================================
# All variables are OPTIONAL. The server starts with any configuration.
# Tools are enabled/disabled based on which API keys you provide.
#
# FULL POWER MODE (all 5 tools enabled):
#   Set all 4 keys: SERPER_API_KEY, REDDIT_CLIENT_ID/SECRET, SCRAPEDO_API_KEY, OPENROUTER_API_KEY
#
# MINIMAL MODE (just web search + reddit search):
#   Set only: SERPER_API_KEY
# ============================================================

# ========== SERPER API ==========
# Enables: search_google, search_reddit
# Get free key (2,500 queries): https://serper.dev
SERPER_API_KEY=

# ========== REDDIT OAUTH ==========
# Enables: fetch_reddit
# Create app: https://www.reddit.com/prefs/apps → "script" type
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# ========== SCRAPE.DO ==========
# Enables: scrape_pages
# Get free key (1,000 credits): https://scrape.do
SCRAPEDO_API_KEY=

# ========== OPENROUTER ==========
# Enables: deep_research + AI extraction in scrape_pages (use_llm, what_to_extract)
# Get API key: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# ============ OPTIONAL TUNING ============

# Deep research model (default: x-ai/grok-4.1-fast)
# Fallback: openai/gpt-oss-120b:nitro
#RESEARCH_MODEL=x-ai/grok-4.1-fast
#RESEARCH_FALLBACK_MODEL=openai/gpt-oss-120b:nitro

# LLM extraction model for scrape_pages (default: openai/gpt-oss-120b:nitro)
#LLM_EXTRACTION_MODEL=openai/gpt-oss-120b:nitro

# Custom OpenRouter endpoint
#OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Research timeout in ms (default: 1800000 = 30 minutes)
#API_TIMEOUT_MS=1800000

# Reasoning effort for deep research: low, medium, high (default: high)
#DEFAULT_REASONING_EFFORT=high

# Max search results per deep research question (default: 100, range: 10-200)
#DEFAULT_MAX_URLS=100

# Enable reasoning in LLM extraction (default: true)
#LLM_ENABLE_REASONING=true
