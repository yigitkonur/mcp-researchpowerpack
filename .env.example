PORT=3000
HOST=127.0.0.1
#ALLOWED_ORIGINS=          # Comma-separated origins for CORS / host validation
#MCP_URL=                  # Public MCP URL fallback for production origin protection

# ── Provider API Keys (each enables its tools) ──
SERPER_API_KEY=             # web-search (all scopes)
REDDIT_CLIENT_ID=           # reddit.com permalinks in scrape-links (threaded post + comments)
REDDIT_CLIENT_SECRET=       # reddit.com permalinks in scrape-links
SCRAPEDO_API_KEY=           # scrape-links (non-reddit URLs)

# ── LLM (AI extraction + search classification + brief generation) ──
# LLM_API_KEY + LLM_BASE_URL + LLM_MODEL are all required together.
# Reasoning effort is always 'low' — not configurable.
LLM_API_KEY=                # API key for your OpenAI-compatible endpoint
LLM_BASE_URL=               # e.g. https://server-production-2696.up.railway.app/v1
LLM_MODEL=gpt-5.4-mini      # primary model
LLM_FALLBACK_MODEL=gpt-5.4  # optional: used after primary exhausts retries (3 more attempts)
#LLM_CONCURRENCY=50         # parallel LLM calls (default: 50, range: 1-200)

# ── Per-provider concurrency overrides ──
#CONCURRENCY_SEARCH=50
#CONCURRENCY_SCRAPER=50
#CONCURRENCY_REDDIT=50

# ── Eval harness ──
EVAL_MCP_URL=http://localhost:3000/mcp
EVAL_MODEL=gpt-5.4-mini
EVAL_API_KEY=
